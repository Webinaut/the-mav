---
import BlogPostLayout from "../../layouts/BlogPostLayout.astro";
import ViewCounter from "../../components/ViewCounter.astro";
import PostComments from "../../components/PostComments.astro";
import Btn from "../../components/Button.astro";

// Import collection rendering tools and our text preprocessor function
import { getEntry, render } from "astro:content";
import { processArticleMarkdown } from "../../content.config";

const { slug } = Astro.params;
if (slug === undefined) {
  throw new Error("Slug is required");
}

const entry = await getEntry("articles", slug);
if (entry === undefined) {
  return Astro.redirect("/404");
}

// FIX: Pre-process the body string on the server before compilation!
if (entry.body) {
  entry.body = processArticleMarkdown(entry.body);
}

const { Content } = await render(entry);
---

<BlogPostLayout frontmatter={entry.data}>
  <article class="article-content">
    <ViewCounter slug={slug} />

    {/* Body elements render optimized HTML natively built on the server */}
    <div class="markdown-body">
      <Content />
    </div>

    <Btn buttonlink="/articles/" buttontext="Back To Articles" />
  </article>

  <article>
    <h3 style="text-align: center;">Comments</h3>
    <p>
      The comments section is a place for healthy, constructive and challenging
      conversations. The basic rule is simple – I encourage you to share your
      views, but be respectful of the author, yourself and your fellow
      commenters. To comment, register or sign in to GitHub (it's free). This
      protects us from spam.
    </p>
    <PostComments />
  </article>
</BlogPostLayout>

<style is:global>
  /* --- MODERN FLEXBOX IMAGE CONTAINER LAYOUT --- */
  .article-content p:has(img.cms-floated-image) {
    display: flex;
    flex-direction: row;
    gap: 2rem;
    align-items: flex-start;
    margin-bottom: 2rem;
    width: 100%;
  }

  /* Base Image Styles */
  .article-content img.cms-floated-image {
    height: auto;
    border-radius: 6px;
    flex-shrink: 0;
  }

  /* --- ALIGNMENT CLASSES USING FLEX ORDER --- */
  .article-content img.align-left {
    order: -1;
  }
  .article-content img.align-right {
    order: 1;
  }
  .article-content p:has(img.align-center) {
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }
  .article-content img.align-center {
    order: 0;
  }

  /* --- WIDTH LAYOUT CLASSES --- */
  .article-content img.size-small {
    width: 30% !important;
  }
  .article-content img.size-medium {
    width: 45% !important;
  }
  .article-content img.size-large {
    width: 60% !important;
  }
  .article-content p:has(img.size-full) {
    flex-direction: column;
    align-items: stretch;
  }
  .article-content img.size-full {
    width: 100% !important;
  }

  /* Repurpose Sveltia margins into dynamic flex gaps */
  .article-content p:has(img.margin-normal) {
    gap: 1.5rem;
  }
  .article-content p:has(img.margin-wide) {
    gap: 2.5rem;
  }

  /* Layout container constraints to keep page blocks organized */
  .article-content blockquote {
    margin: 2rem 0;
    padding: 1rem 1.5rem;
    border-left: 4px solid #ccc;
    width: 100%;
    box-sizing: border-box;
  }
</style>
