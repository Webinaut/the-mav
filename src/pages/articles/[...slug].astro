---
import BlogPostLayout from "../../layouts/BlogPostLayout.astro";
import ViewCounter from "../../components/ViewCounter.astro";
import PostComments from "../../components/PostComments.astro";
import Btn from "../../components/Button.astro";

// SSR Code
import { getEntry, render } from "astro:content";

const { slug } = Astro.params;
if (slug === undefined) {
  throw new Error("Slug is required");
}

const entry = await getEntry("articles", slug);
if (entry === undefined) {
  return Astro.redirect("/404");
}

// FIX: Intercept the body raw string text and map the shortcode to standard HTML output elements
if (entry.body) {
  const shortcodeRegex =
    /\[floated-image\s+image="([^"]+)"\s+alt="([^"]*)"\s+align="([^"]+)"\s*\]/g;

  entry.body = entry.body.replace(
    shortcodeRegex,
    (match, image, alt, align) => {
      // Computes relative asset resolution path parameters if image tracks locally
      const cleanSrc = image.startsWith("./") ? image.substring(2) : image;

      return `<div class="floated-image-container align-${align}">
      <img src="${cleanSrc}" alt="${alt}" />
    </div>`;
    },
  );
}

const { Content } = await render(entry);
---

<BlogPostLayout frontmatter={entry.data}>
  <article class="article-content">
    <ViewCounter slug={slug} />
    {/* Safely render the compiled contents cleanly */}
    <Content />
    <Btn buttonlink="/articles/" buttontext="Back To Articles" />
  </article>

  <article>
    <h3 style="text-align: center;">Comments</h3>
    <p>
      The comments section is a place for healthy, constructive and challenging
      conversations. The basic rule is simple – I encourage you to share your
      views, but be respectful of the author, yourself and your fellow
      commenters. To comment, register or sign in to GitHub (it's free). This
      protects us from spam.
    </p>
    <PostComments />
  </article>
</BlogPostLayout>

<style is:global>
  /* Target the images inside your article content using their URL string hash attributes */
  .article-content img[src*="#left"] {
    float: left;
    max-width: 40%;
    margin: 1rem 2rem 1rem 0;
  }

  .article-content img[src*="#right"] {
    float: right;
    max-width: 40%;
    margin: 1rem 0 1rem 2rem;
  }

  .article-content img[src*="#center"] {
    display: block;
    margin: 2rem auto;
    max-width: 80%;
  }

  /* Clear fix layout helper wrapper */
  .article-content::after {
    content: "";
    display: table;
    clear: both;
  }
</style>
