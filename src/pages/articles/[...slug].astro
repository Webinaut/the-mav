---
import BlogPostLayout from "../../layouts/BlogPostLayout.astro";
import ViewCounter from "../../components/ViewCounter.astro";
import PostComments from "../../components/PostComments.astro";
import Btn from "../../components/Button.astro";

import { getEntry, render } from "astro:content";

const { slug } = Astro.params;
if (slug === undefined) {
  throw new Error("Slug is required");
}

const entry = await getEntry("articles", slug);
if (entry === undefined) {
  return Astro.redirect("/404");
}

const { Content } = await render(entry);
---

<BlogPostLayout frontmatter={entry.data}>
  <article class="article-content">
    <ViewCounter slug={slug} />

    {/* Target container for our property script */}
    <div id="production-markdown-content" class="markdown-body">
      <Content />
    </div>

    <Btn buttonlink="/articles/" buttontext="Back To Articles" />
  </article>

  <article>
    <h3 style="text-align: center;">Comments</h3>
    <p>
      The comments section is a place for healthy, constructive and challenging
      conversations. The basic rule is simple – I encourage you to share your
      views, but be respectful of the author, yourself and your fellow
      commenters. To comment, register or sign in to GitHub (it's free). This
      protects us from spam.
    </p>
    <PostComments />
  </article>
</BlogPostLayout>

{/* ROBUST DYNAMIC ALT PROPERTY PARSER SCRIPT */}
<script is:inline>
  (function () {
    function processImages() {
      const contentArea = document.getElementById(
        "production-markdown-content",
      );
      if (!contentArea) return;

      const images = contentArea.getElementsByTagName("img");

      for (let i = 0; i < images.length; i++) {
        const img = images[i];
        const altText = img.getAttribute("alt") || "";

        // Extract styling data from pipe delimiters saved by Sveltia
        if (altText && altText.includes("|")) {
          const parts = altText.split("|");

          // Isolate the clean display title description
          const cleanAltLabel = parts[0].trim();

          // Intelligent fallbacks
          let align = "right";
          let size = "size-medium";
          let margin = "margin-normal";

          // Scan variable positions safely
          for (let j = 1; j < parts.length; j++) {
            const segment = parts[j].trim();

            if (
              segment === "left" ||
              segment === "right" ||
              segment === "center"
            ) {
              align = segment;
            }
            if (segment.includes("size-")) {
              if (segment.includes("_")) {
                const subStyles = segment.split("_");
                size = subStyles[0];
                margin = subStyles[1];
              } else {
                size = segment;
              }
            }
          }

          // 1. Reassign clean alt title label string
          img.setAttribute("alt", cleanAltLabel);

          // 2. Inject active design layout CSS classes
          img.className = "";
          img.classList.add("cms-floated-image");
          img.classList.add("align-" + align);
          img.classList.add(size);
          img.classList.add(margin);
        }
      }
    }

    // Process variables instantly upon DOM element generation
    processImages();

    // Structural observer fallback map
    const targetNode = document.getElementById("production-markdown-content");
    if (targetNode) {
      const observer = new MutationObserver(processImages);
      observer.observe(targetNode, { childList: true, subtree: true });
    }
  })();
</script>

<style is:global>
  /* --- CLEAN UNIFIED ADVANCED FLOATING LAYOUT --- */

  /* Base Image Configuration rules */
  .article-content img.cms-floated-image {
    height: auto;
    display: inline-block;
    border-radius: 6px;
    max-width: 100%;
    box-sizing: border-box;
  }

  /* --- ALIGNMENT STYLES --- */
  .article-content img.align-left {
    float: left;
    clear: left;
  }
  .article-content img.align-right {
    float: right;
    clear: right;
  }
  .article-content img.align-center {
    display: block;
    float: none;
    margin-left: auto;
    margin-right: auto;
    clear: both;
  }

  /* --- WIDTH LAYOUT CLASSES --- */
  .article-content img.size-small {
    width: 30% !important;
  }
  .article-content img.size-medium {
    width: 45% !important;
  }
  .article-content img.size-large {
    width: 60% !important;
  }
  .article-content img.size-full {
    width: 100% !important;
    display: block;
    margin-top: 2rem;
    margin-bottom: 2rem;
    clear: both;
  }

  /* --- MARGIN CONFIGURATION CLASSES --- */
  .article-content img.align-left.margin-normal {
    margin: 0.5rem 1.5rem 1rem 0 !important;
  }
  .article-content img.align-left.margin-wide {
    margin: 1.5rem 2.5rem 2rem 0 !important;
  }

  .article-content img.align-right.margin-normal {
    margin: 0.5rem 0 1rem 1.5rem !important;
  }
  .article-content img.align-right.margin-wide {
    margin: 1.5rem 0 2rem 2.5rem !important;
  }

  /* --- VERTICAL LAYOUT CONTROLS --- */

  /* Forces headings, blockquotes, and dividers to wait until the image is finished before rendering vertically */
  .article-content blockquote,
  .article-content h1,
  .article-content h2,
  .article-content h3,
  .article-content h4,
  .article-content hr,
  .article-content pre {
    clear: both;
    display: flow-root; /* Keeps layout blocks structurally square and self-contained */
  }

  .article-content blockquote {
    margin: 2rem 0;
    padding: 1rem 1.5rem;
    border-left: 4px solid #ccc;
    box-sizing: border-box;
  }

  /* Container clearfix helper */
  .article-content::after {
    content: "";
    display: table;
    clear: both;
  }
</style>
