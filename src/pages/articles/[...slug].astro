---
import BlogPostLayout from "../../layouts/BlogPostLayout.astro";
import ViewCounter from "../../components/ViewCounter.astro";
import PostComments from "../../components/PostComments.astro";
import Btn from "../../components/Button.astro";

// SSR Code
import { getEntry, render } from "astro:content";

const { slug } = Astro.params;
if (slug === undefined) {
  throw new Error("Slug is required");
}

const entry = await getEntry("articles", slug);
if (entry === undefined) {
  return Astro.redirect("/404");
}

// FIX: Intercept the body raw string text and map the shortcode to standard HTML output elements
if (entry.body) {
  const shortcodeRegex =
    /\[floated-image\s+image="([^"]+)"\s+alt="([^"]*)"\s+align="([^"]+)"\s*\]/g;

  entry.body = entry.body.replace(
    shortcodeRegex,
    (match, image, alt, align) => {
      // Computes relative asset resolution path parameters if image tracks locally
      const cleanSrc = image.startsWith("./") ? image.substring(2) : image;

      return `<div class="floated-image-container align-${align}">
      <img src="${cleanSrc}" alt="${alt}" />
    </div>`;
    },
  );
}

const { Content } = await render(entry);
---

<BlogPostLayout frontmatter={entry.data}>
  <article class="article-content">
    <ViewCounter slug={slug} />
    {/* Safely render the compiled contents cleanly */}
    <Content />
    <Btn buttonlink="/articles/" buttontext="Back To Articles" />
  </article>

  <article>
    <h3 style="text-align: center;">Comments</h3>
    <p>
      The comments section is a place for healthy, constructive and challenging
      conversations. The basic rule is simple – I encourage you to share your
      views, but be respectful of the author, yourself and your fellow
      commenters. To comment, register or sign in to GitHub (it's free). This
      protects us from spam.
    </p>
    <PostComments />
  </article>
</BlogPostLayout>

<style is:global>
  /* Base Image Styles */
  .article-content img {
    height: auto;
    display: inline-block;
    border-radius: 6px;
  }

  /* --- ALIGNMENT CLASSES --- */
  .article-content img[src*="#left_"] {
    float: left;
  }
  .article-content img[src*="#right_"] {
    float: right;
  }
  .article-content img[src*="#center_"] {
    display: block;
    float: none;
    margin-left: auto;
    margin-right: auto;
  }

  /* --- WIDTH LAYOUT CLASSES --- */
  .article-content img[src*="_size-small"] {
    width: 30%;
  }
  .article-content img[src*="_size-medium"] {
    width: 45%;
  }
  .article-content img[src*="_size-large"] {
    width: 60%;
  }
  .article-content img[src*="_size-full"] {
    width: 100%;
    display: block;
    margin-top: 2rem;
    margin-bottom: 2rem;
  }

  /* --- MARGIN CONFIGURATION CLASSES --- */
  /* Left Aligned Spacing rules */
  .article-content img[src*="#left"][src*="_margin-normal"] {
    margin: 0.5rem 1.5rem 1rem 0;
  }
  .article-content img[src*="#left"][src*="_margin-wide"] {
    margin: 1.5rem 2.5rem 2rem 0;
  }

  /* Right Aligned Spacing rules */
  .article-content img[src*="#right"][src*="_margin-normal"] {
    margin: 0.5rem 0 1rem 1.5rem;
  }
  .article-content img[src*="#right"][src*="_margin-wide"] {
    margin: 1.5rem 0 2rem 2.5rem;
  }

  /* Layout container clearfix to keep text flowing smoothly */
  .article-content::after {
    content: "";
    display: table;
    clear: both;
  }
</style>
