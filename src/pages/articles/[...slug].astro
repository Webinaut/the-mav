---
import BlogPostLayout from "../../layouts/BlogPostLayout.astro";
import ViewCounter from "../../components/ViewCounter.astro";
import PostComments from "../../components/PostComments.astro";
import Btn from "../../components/Button.astro";

import { getEntry, render } from "astro:content";

const { slug } = Astro.params;
if (slug === undefined) {
  throw new Error("Slug is required");
}

const entry = await getEntry("articles", slug);
if (entry === undefined) {
  return Astro.redirect("/404");
}

// Fixed: Single argument rendering prevents Astro 5 server-side template crashes
const { Content } = await render(entry);
---

<BlogPostLayout frontmatter={entry.data}>
  <article class="article-content">
    <ViewCounter slug={slug} />

    {/* Bound container for our client script to process */}
    <div id="production-markdown-content" class="markdown-body">
      <Content />
    </div>

    <Btn buttonlink="/articles/" buttontext="Back To Articles" />
  </article>

  <article>
    <h3 style="text-align: center;">Comments</h3>
    <p>
      The comments section is a place for healthy, constructive and challenging
      conversations. The basic rule is simple – I encourage you to share your
      views, but be respectful of the author, yourself and your fellow
      commenters. To comment, register or sign in to GitHub (it's free). This
      protects us from spam.
    </p>
    <PostComments />
  </article>
</BlogPostLayout>

{/* CLEAN RE-MAPPING SCRIPT */}
<script is:inline>
  (function () {
    const contentArea = document.getElementById("production-markdown-content");
    if (!contentArea) return;

    const images = contentArea.getElementsByTagName("img");
    const isLocalhost =
      window.location.hostname === "localhost" ||
      window.location.hostname === "127.0.0.1";

    for (let i = 0; i < images.length; i++) {
      const img = images[i];
      let rawConfigString = "";

      // 1. Unpack Astro 5's internal metadata object configuration tracking map
      if (img.hasAttribute("__astro_image_")) {
        try {
          const astroData = JSON.parse(img.getAttribute("__astro_image_"));
          if (astroData && astroData.src) {
            rawConfigString = astroData.src;
          }
        } catch (e) {
          console.error(
            "Failed parsing internal __astro_image_ metadata block:",
            e,
          );
        }
      }

      if (!rawConfigString) {
        rawConfigString = img.getAttribute("src") || "";
      }

      // 2. Parse out your custom configuration options
      if (rawConfigString && rawConfigString.includes("#")) {
        const parts = rawConfigString.split("#");
        const cleanAstroSrc = parts;
        const hashConfig = parts;

        if (hashConfig) {
          const styles = hashConfig.split("_");
          const align = styles || "right";
          const size = styles || "size-medium";
          const margin = styles || "margin-normal";

          // 3. Map the source path dynamically based on your active server environment
          if (isLocalhost) {
            // Local Development: Force directory matching for the Vite middleware to catch
            let currentPath = window.location.pathname;
            if (!currentPath.endsWith("/")) currentPath += "/";
            const fileFragment = cleanAstroSrc.split("/").pop();
            img.setAttribute("src", currentPath + fileFragment);
          } else {
            // Live Netlify Production: Use Astro's natively built, optimized, hashed image path string directly
            img.setAttribute("src", cleanAstroSrc);
          }

          // 4. Clean up temporary parameters to prevent layout conflicts
          img.removeAttribute("srcset");
          img.removeAttribute("__astro_image_");

          // 5. Apply your Flexbox display classes
          img.className = "";
          img.classList.add("cms-floated-image");
          img.classList.add("align-" + align);
          img.classList.add(size);
          img.classList.add(margin);
        }
      }
    }
  })();
</script>

<style is:global>
  /* --- MODERN FLEXBOX PARAGRAPH STRUCTURE --- */
  .article-content p:has(img.cms-floated-image) {
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    margin-bottom: 2rem;
    width: 100%;
  }

  /* Base Image Styles */
  .article-content img.cms-floated-image {
    height: auto;
    border-radius: 6px;
    flex-shrink: 0;
  }

  /* --- ALIGNMENT CLASSES VIA FLEX ORDER --- */
  .article-content img.align-left {
    order: -1;
  }
  .article-content img.align-right {
    order: 1;
  }
  .article-content p:has(img.align-center) {
    flex-direction: column;
    align-items: center;
  }
  .article-content img.align-center {
    order: 0;
  }

  /* --- WIDTH LAYOUT CLASSES --- */
  .article-content img.size-small {
    width: 30% !important;
  }
  .article-content img.size-medium {
    width: 45% !important;
  }
  .article-content img.size-large {
    width: 60% !important;
  }
  .article-content p:has(img.size-full) {
    flex-direction: column;
    align-items: stretch;
  }
  .article-content img.size-full {
    width: 100% !important;
  }

  /* Map spacing parameters directly to modern layout gaps */
  .article-content p:has(img.margin-normal) {
    gap: 1.5rem;
  }
  .article-content p:has(img.margin-wide) {
    gap: 2.5rem;
  }

  /* Keep blockquotes beautifully isolated from overlapping margins */
  .article-content blockquote {
    margin: 2rem 0;
    padding: 1rem 1.5rem;
    border-left: 4px solid #ccc;
    width: 100%;
    box-sizing: border-box;
  }
</style>
