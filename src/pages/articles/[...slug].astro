---
import BlogPostLayout from "../../layouts/BlogPostLayout.astro";
import ViewCounter from "../../components/ViewCounter.astro";
import PostComments from "../../components/PostComments.astro";
import Btn from "../../components/Button.astro";

// SSR Code
import { getEntry, render } from "astro:content";

const { slug } = Astro.params;
if (slug === undefined) {
  throw new Error("Slug is required");
}

const entry = await getEntry("articles", slug);
if (entry === undefined) {
  return Astro.redirect("/404");
}

// FIX: Server-Side Shortcode Interceptor Loop
if (entry.body) {
  // Regex to isolate custom parameters: e.g. ![Alt](./image.jpg#left_size-medium_margin-normal)
  const imageRegex =
    /!\[(?<alt>[^\]]*)\]\((?:\.\/)?(?<image>[^)#\s]+)#(?<align>left|right|center)_(?<size_class>[a-zA-Z0-9_-]+)\)/g;

  entry.body = entry.body.replace(
    imageRegex,
    (match, alt, image, align, size_class) => {
      // Force a clean path structure that Astro's native parser can read relative to the page bundle
      const cleanSrc = image.startsWith("./") ? image : `./${image}`;

      // Parse out potential compound margin settings from the saved class token
      const marginClass = size_class.includes("_")
        ? size_class.split("_")[1]
        : "margin-normal";
      const cleanSize = size_class.split("_")[0];

      // Injects valid standard HTML directly into the text stream before compilation
      return `<img src="${cleanSrc}" alt="${alt}" class="cms-floated-image align-${align} ${cleanSize} ${marginClass}" />`;
    },
  );
}

const { Content } = await render(entry);
---

<BlogPostLayout frontmatter={entry.data}>
  <article class="article-content">
    <ViewCounter slug={slug} />

    {
      /* Content loads clean native HTML markup compiled directly on the server */
    }
    <div class="markdown-body">
      <Content />
    </div>

    <Btn buttonlink="/articles/" buttontext="Back To Articles" />
  </article>

  <article>
    <h3 style="text-align: center;">Comments</h3>
    <p>
      The comments section is a place for healthy, constructive and challenging
      conversations. The basic rule is simple – I encourage you to share your
      views, but be respectful of the author, yourself and your fellow
      commenters. To comment, register or sign in to GitHub (it's free). This
      protects us from spam.
    </p>
    <PostComments />
  </article>
</BlogPostLayout>

<style is:global>
  /* Base Image Configuration rules */
  .article-content img.cms-floated-image {
    height: auto;
    display: inline-block;
    border-radius: 6px;
    max-width: 100%;
  }

  /* --- ALIGNMENT CLASSES --- */
  .article-content img.align-left {
    float: left;
  }
  .article-content img.align-right {
    float: right;
  }
  .article-content img.align-center {
    display: block;
    float: none;
    margin-left: auto;
    margin-right: auto;
  }

  /* --- WIDTH LAYOUT CLASSES --- */
  .article-content img.size-small {
    width: 30% !important;
  }
  .article-content img.size-medium {
    width: 45% !important;
  }
  .article-content img.size-large {
    width: 60% !important;
  }
  .article-content img.size-full {
    width: 100% !important;
    display: block;
    margin-top: 2rem;
    margin-bottom: 2rem;
  }

  /* --- MARGIN CONFIGURATION CLASSES --- */
  .article-content img.align-left.margin-normal {
    margin: 0.5rem 1.5rem 1rem 0;
  }
  .article-content img.align-left.margin-wide {
    margin: 1.5rem 2.5rem 2rem 0;
  }

  .article-content img.align-right.margin-normal {
    margin: 0.5rem 0 1rem 1.5rem;
  }
  .article-content img.align-right.margin-wide {
    margin: 1.5rem 0 2rem 2.5rem;
  }

  /* Layout container clearfix to keep content structured cleanly */
  .article-content::after {
    content: "";
    display: table;
    clear: both;
  }
</style>
