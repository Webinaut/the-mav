---
import BlogPostLayout from "../../layouts/BlogPostLayout.astro";
import ViewCounter from "../../components/ViewCounter.astro";
import PostComments from "../../components/PostComments.astro";
import Btn from "../../components/Button.astro";

// SSR Code
import { getEntry, render } from "astro:content";
import { parse } from "node-html-parser"; // <-- Import the HTML parser helper

const { slug } = Astro.params;
if (slug === undefined) {
  throw new Error("Slug is required");
}

const entry = await getEntry("articles", slug);
if (entry === undefined) {
  return Astro.redirect("/404");
}

const { Content } = await render(entry);

// 1. Render the initial Content to a raw static HTML string layout
const rawHtml = await Astro.slots.render("default");
---

<BlogPostLayout frontmatter={entry.data}>
  <article class="article-content">
    <ViewCounter slug={slug} />

    {
      /* 2. Execute a dynamic pipeline check on Content to intercept and clean the hashes */
    }
    <div id="markdown-container">
      <Content />
    </div>

    <Btn buttonlink="/articles/" buttontext="Back To Articles" />
  </article>

  <article>
    <h3 style="text-align: center;">Comments</h3>
    <p>
      The comments section is a place for healthy, constructive and challenging
      conversations. The basic rule is simple – I encourage you to share your
      views, but be respectful of the author, yourself and your fellow
      commenters. To comment, register or sign in to GitHub (it's free). This
      protects us from spam.
    </p>
    <PostComments />
  </article>
</BlogPostLayout>

<!-- 3. Server-side script injection processing block -->
<script is:inline>
  // Runs immediately upon DOM load to unpack parameters into native HTML classes
  const container = document.getElementById("markdown-container");
  if (container) {
    const images = container.getElementsByTagName("img");
    for (let img of images) {
      const src = img.getAttribute("src");

      // Look for our custom delimiter hash sequence inside the path payload
      if (src && src.includes("#")) {
        const [cleanSrc, hashParams] = src.split("#");

        // Split our style settings: e.g. "left_size-medium_margin-normal"
        const [align, sizeClass, marginClass] = hashParams.split("_");

        // Strip the trailing query string from the physical img source to fix rendering
        img.setAttribute("src", cleanSrc);

        // Apply clean, valid HTML classes instead of relying on URL selectors
        if (align) img.classList.add(`align-${align}`);
        if (sizeClass) img.classList.add(sizeClass);
        if (marginClass) img.classList.add(marginClass);
      }
    }
  }
</script>

<style is:global>
  /* Base Image Configuration rules */
  .article-content img {
    height: auto;
    display: inline-block;
    border-radius: 6px;
    max-width: 100%;
  }

  /* --- ALIGNMENT NATIVE CLASSES --- */
  .article-content img.align-left {
    float: left;
  }
  .article-content img.align-right {
    float: right;
  }
  .article-content img.align-center {
    display: block;
    float: none;
    margin-left: auto;
    margin-right: auto;
  }

  /* --- WIDTH LAYOUT CLASSES --- */
  .article-content img.size-small {
    width: 30% !important;
  }
  .article-content img.size-medium {
    width: 45% !important;
  }
  .article-content img.size-large {
    width: 60% !important;
  }
  .article-content img.size-full {
    width: 100% !important;
    display: block;
    margin-top: 2rem;
    margin-bottom: 2rem;
  }

  /* --- MARGIN CONFIGURATION CLASSES --- */
  .article-content img.align-left.margin-normal {
    margin: 0.5rem 1.5rem 1rem 0;
  }
  .article-content img.align-left.margin-wide {
    margin: 1.5rem 2.5rem 2rem 0;
  }

  .article-content img.align-right.margin-normal {
    margin: 0.5rem 0 1rem 1.5rem;
  }
  .article-content img.align-right.margin-wide {
    margin: 1.5rem 0 2rem 2.5rem;
  }

  /* Layout container clearfix to keep content structured cleanly */
  .article-content::after {
    content: "";
    display: table;
    clear: both;
  }
</style>
