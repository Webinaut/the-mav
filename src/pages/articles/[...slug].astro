---
import BlogPostLayout from "../../layouts/BlogPostLayout.astro";
import ViewCounter from "../../components/ViewCounter.astro";
import PostComments from "../../components/PostComments.astro";
import Btn from "../../components/Button.astro";

import { getEntry, render } from "astro:content";

const { slug } = Astro.params;
if (slug === undefined) {
  throw new Error("Slug is required");
}

const entry = await getEntry("articles", slug);
if (entry === undefined) {
  return Astro.redirect("/404");
}

const { Content } = await render(entry);

// 1. Render markdown elements to a raw HTML text block
let htmlContent = await Astro.slots.render("default", []);
if (!htmlContent) {
  // Fallback rendering container helper if slots execution returns empty payload loops
  htmlContent = `<div id="astro-rendered-content"></div>`;
}

// 2. Server-Side HTML Regex transformation script
// Target matches: src="/_astro/image.hashname.jpg#left_size-medium_margin-normal"
const imgTagRegex =
  /<img([^>]+)src=["']([^"']+)#(?<align>left|right|center)_(?<size_class>[a-zA-Z0-9_-]+)["']([^>]*)>/g;

const processedHtml = htmlContent.replace(
  imgTagRegex,
  (match, beforeSrc, srcPath, align, size_class, afterSrc) => {
    const parts = size_class.split("_");
    const size = parts[0] || "size-medium";
    const margin = parts[1] || "margin-normal";

    // Return a clean HTML tag string with the hash stripped from the source path
    return `<img ${beforeSrc} src="${srcPath}" class="cms-floated-image align-${align} ${size} ${margin}" ${afterSrc} />`;
  },
);
---

<BlogPostLayout frontmatter={entry.data}>
  <article class="article-content">
    <ViewCounter slug={slug} />

    {/* 3. Output the processed layout directly to the server stream wrapper */}
    {
      processedHtml.includes("cms-floated-image") ? (
        <div class="markdown-body" set:html={processedHtml} />
      ) : (
        <div class="markdown-body">
          <Content />
        </div>
      )
    }

    <Btn buttonlink="/articles/" buttontext="Back To Articles" />
  </article>

  <article>
    <h3 style="text-align: center;">Comments</h3>
    <p>
      The comments section is a place for healthy, constructive and challenging
      conversations. The basic rule is simple – I encourage you to share your
      views, but be respectful of the author, yourself and your fellow
      commenters. To comment, register or sign in to GitHub (it's free). This
      protects us from spam.
    </p>
    <PostComments />
  </article>
</BlogPostLayout>

<style is:global>
  /* Global Float Layout Style Variables */
  .article-content img.cms-floated-image {
    height: auto;
    display: inline-block;
    border-radius: 6px;
    max-width: 100%;
  }

  /* --- ALIGNMENT CLASSES --- */
  .article-content img.align-left {
    float: left;
  }
  .article-content img.align-right {
    float: right;
  }
  .article-content img.align-center {
    display: block;
    float: none;
    margin-left: auto;
    margin-right: auto;
  }

  /* --- WIDTH LAYOUT CLASSES --- */
  .article-content img.size-small {
    width: 30% !important;
  }
  .article-content img.size-medium {
    width: 45% !important;
  }
  .article-content img.size-large {
    width: 60% !important;
  }
  .article-content img.size-full {
    width: 100% !important;
    display: block;
    margin-top: 2rem;
    margin-bottom: 2rem;
  }

  /* --- MARGIN CONFIGURATION CLASSES --- */
  .article-content img.align-left.margin-normal {
    margin: 0.5rem 1.5rem 1rem 0;
  }
  .article-content img.align-left.margin-wide {
    margin: 1.5rem 2.5rem 2rem 0;
  }

  .article-content img.align-right.margin-normal {
    margin: 0.5rem 0 1rem 1.5rem;
  }
  .article-content img.align-right.margin-wide {
    margin: 1.5rem 0 2rem 2.5rem;
  }

  .article-content::after {
    content: "";
    display: table;
    clear: both;
  }
</style>
