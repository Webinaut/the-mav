---
import BlogPostLayout from "../../layouts/BlogPostLayout.astro";
import ViewCounter from "../../components/ViewCounter.astro";
import PostComments from "../../components/PostComments.astro";
import Btn from "../../components/Button.astro";

import { getEntry, render } from "astro:content";

const { slug } = Astro.params;
if (slug === undefined) {
  throw new Error("Slug is required");
}

const entry = await getEntry("articles", slug);
if (entry === undefined) {
  return Astro.redirect("/404");
}

const { Content } = await render(entry);
---

<BlogPostLayout frontmatter={entry.data}>
  <article class="article-content">
    <ViewCounter slug={slug} />

    {/* Clean, standard content execution canvas hook */}
    <div id="cms-rendering-wrapper" class="markdown-body">
      <Content />
    </div>

    <Btn buttonlink="/articles/" buttontext="Back To Articles" />
  </article>

  <article>
    <h3 style="text-align: center;">Comments</h3>
    <p>
      The comments section is a place for healthy, constructive and challenging
      conversations. The basic rule is simple – I encourage you to share your
      views, but be respectful of the author, yourself and your fellow
      commenters. To comment, register or sign in to GitHub (it's free). This
      protects us from spam.
    </p>
    <PostComments />
  </article>
</BlogPostLayout>

{
  /* INLINE RENDERING SCRIPT: Strips image hash values and maps configuration parameters to CSS classes */
}
<script is:inline>
  (function () {
    const wrapper = document.getElementById("cms-rendering-wrapper");
    if (!wrapper) return;

    // Scan the content block looking for rendered image elements
    const images = wrapper.getElementsByTagName("img");

    for (let i = 0; i < images.length; i++) {
      const img = images[i];
      const src = img.getAttribute("src");

      // Intercept our custom parameter hashes (e.g., #left_size-medium_margin-normal)
      if (src && src.includes("#")) {
        const parts = src.split("#");
        const cleanSrc = parts[0];
        const hashParams = parts[1];

        if (hashParams) {
          const config = hashParams.split("_");
          const align = config[0] || "right";
          const size = config[1] || "size-medium";
          const margin = config[2] || "margin-normal";

          // 1. Strip the hash string from the image element source so the file displays properly
          img.setAttribute("src", cleanSrc);

          // 2. Clear any data parameters that could break the layout engine
          img.removeAttribute("srcset");

          // 3. Inject clean HTML classes directly onto the active rendering node
          img.classList.add("cms-floated-image");
          img.classList.add(`align-${align}`);
          img.classList.add(size);
          img.classList.add(margin);
        }
      }
    }
  })();
</script>

<style is:global>
  /* Global Float Layout Styles */
  .article-content img.cms-floated-image {
    height: auto;
    display: inline-block;
    border-radius: 6px;
    max-width: 100%;
  }

  /* --- ALIGNMENT CLASSES --- */
  .article-content img.align-left {
    float: left;
  }
  .article-content img.align-right {
    float: right;
  }
  .article-content img.align-center {
    display: block;
    float: none;
    margin-left: auto;
    margin-right: auto;
  }

  /* --- WIDTH LAYOUT CLASSES --- */
  .article-content img.size-small {
    width: 30% !important;
  }
  .article-content img.size-medium {
    width: 45% !important;
  }
  .article-content img.size-large {
    width: 60% !important;
  }
  .article-content img.size-full {
    width: 100% !important;
    display: block;
    margin-top: 2rem;
    margin-bottom: 2rem;
  }

  /* --- MARGIN CONFIGURATION CLASSES --- */
  .article-content img.align-left.margin-normal {
    margin: 0.5rem 1.5rem 1rem 0 !important;
  }
  .article-content img.align-left.margin-wide {
    margin: 1.5rem 2.5rem 2rem 0 !important;
  }

  .article-content img.align-right.margin-normal {
    margin: 0.5rem 0 1rem 1.5rem !important;
  }
  .article-content img.align-right.margin-wide {
    margin: 1.5rem 0 2rem 2.5rem !important;
  }

  /* Clearfix layout guard rule to prevent flowing elements from clipping content containers */
  .article-content::after {
    content: "";
    display: table;
    clear: both;
  }
</style>
